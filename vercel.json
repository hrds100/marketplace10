{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://maps.googleapis.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https: wss:; frame-src 'self' https:; worker-src 'self' blob:; media-src 'self' https: blob:;"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "https://asazddtvjvmckouxcmmo.supabase.co/functions/v1/health"
    },
    {
      "source": "/api/ghl-webhook",
      "destination": "https://asazddtvjvmckouxcmmo.supabase.co/functions/v1/receive-tenant-whatsapp"
    },
    {
      "source": "/auth/:path*",
      "destination": "/app.html"
    },
    {
      "source": "/signin",
      "destination": "/app.html"
    },
    {
      "source": "/signup",
      "destination": "/app.html"
    },
    {
      "source": "/verify-otp",
      "destination": "/app.html"
    },
    {
      "source": "/forgot-password",
      "destination": "/app.html"
    },
    {
      "source": "/reset-password",
      "destination": "/app.html"
    },
    {
      "source": "/inbox",
      "destination": "/app.html"
    },
    {
      "source": "/deals/:path*",
      "destination": "/app.html"
    },
    {
      "source": "/lead/:path*",
      "destination": "/app.html"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/app.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/app.html"
    },
    {
      "source": "/privacy",
      "destination": "/app.html"
    },
    {
      "source": "/terms",
      "destination": "/app.html"
    },
    {
      "source": "/brand",
      "destination": "/app.html"
    }
  ]
}
